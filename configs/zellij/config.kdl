// Examples:
//   - https://github.com/D3B-0x0/dotfiles/blob/main/.config/zellij/config.kdl


// The name of the default layout to load on startup
default_layout "default"

// Choose the mode that zellij uses when starting up.
default_mode "normal"

// Choose the path to the default shell that zellij will use for opening new panes
// Default: $SHELL
//
// default_shell "fish"

// If enabled, sessions will be serialized to the cache folder (and thus become resurrectable
// between reboots or on exit). Read more about session resurrection.
session_serialization false

// Show startup tips
show_startup_tips false

// Whether to show release notes on first version run
show_release_notes false

// Send a request for a simplified ui (without arrow fonts) to plugins
simplified_ui true

// Choose the theme that is specified in the themes section.
theme "catppuccin-mocha"

// Choose what to do when zellij receives SIGTERM, SIGINT, SIGQUIT or SIGHUP
// eg. when terminal window with an active zellij session is closed
// (Requires restart)
// Options:
//   - detach (Default)
//   - quit
//
on_force_close "quit"

// Enable automatic copying (and clearing) of selection when releasing mouse
copy_on_select true

// -----------------------------------------------------------------------------
// UI
// -----------------------------------------------------------------------------

ui {
    pane_frames {
        hide_session_name false
        rounded_corners true
    }
}

// -------------------------------------------------------------------------------------
// Plugins
// -------------------------------------------------------------------------------------

plugins {
    tab-bar { path "tab-bar"; }
    status-bar { path "status-bar"; }
    strider { path "strider"; }
    compact-bar { path "compact-bar"; }
    zjstatus location="file:/Users/neo/.config/zellij/plugins/zjstatus.wasm"
    zjstatus-hints location="file:/Users/neo/.config/zellij/plugins/zjstatus-hints.wasm" {
        // See: https://github.com/b0o/zjstatus-hints/pull/30#issuecomment-3995367563
        modifier_style "symbol"
        overflow_str "…"
        max_keys "1"
        separator " "
        italic true
        transparent_bg true

        // hint_format "{action}[{key}]"
        hint_format "{key}:{action}"
        key_alias_enter "⏎"
        key_alias_space "␣"
        key_alias_esc   "⎋"
        key_alias_tab   "⇥"

        // Global — applies to all hints
        key_fg   "#494d64"
        key_bg   "#101C2C"
        label_fg "#494d64"
        label_bg "#101C2C"
    }
}

load_plugins {
    zjstatus-hints
}

// -----------------------------------------------------------------------------
// Theme
// -----------------------------------------------------------------------------

