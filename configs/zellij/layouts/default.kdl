// https://github.com/wiraki/dotfiles/blob/main/private_dot_config/zellij/layouts/default.kdl

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            // plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm"
            plugin location="zjstatus" {
                format_left   " {mode}#[bg=#101C2C] {tabs}"
                format_center "#[fg=#494d64,italic]{session}"
                // format_right  "{command_cpu} #[fg=#494d64]â‹® {command_memo} "

                // Show status and hints:
                //   - https://github.com/dj95/zjstatus/discussions/44#discussioncomment-13395482
                //   - https://github.com/b0o/zjstatus-hints/pull/30
                format_right  "{pipe_zjstatus_hints} "
                pipe_zjstatus_hints_format "#[bg=#101C2C,fg=#FEA871]{output}"

                // -- mode -----
                mode_normal        "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï’‰ #[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_locked        "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]î¸• #[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_pane          "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï‹’ #[bg=#FEA871,fg=#101C2C,bold]Pane#[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_renamepane    "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï‹’ #[bg=#FEA871,fg=#101C2C,bold]Rename Pane#[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_resize        "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ïگ¤ #[bg=#FEA871,fg=#101C2C,bold]Resize#[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_move          "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï„¤ #[bg=#FEA871,fg=#101C2C,bold]Move#[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_tab           "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï„Œ #[bg=#FEA871,fg=#101C2C,bold]Tab#[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_scroll        "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï‡ک #[bg=#FEA871,fg=#101C2C,bold]Scroll#[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_search        "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï€‚ #[bg=#FEA871,fg=#101C2C,bold]Search#[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_entersearch  "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï€‚ #[bg=#FEA871,fg=#101C2C,bold]Enter Search#[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_renametab    "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï‘‘ #[bg=#FEA871,fg=#101C2C,bold]Rename Tab#[bg=#101C2C,fg=#FEA871,bold]î‚´"
                mode_session       "#[bg=#101C2C,fg=#FEA871]î‚¶#[bg=#FEA871,fg=#101C2C,bold]ï‘ھ #[bg=#FEA871,fg=#101C2C,bold]Session#[bg=#101C2C,fg=#FEA871,bold]î‚´"

                // -- tab -----
                tab_normal              "#[bg=#101C2C,fg=#363a4f]î‚¶#[bg=#363a4f,fg=#eed49f,bold]{name}{floating_indicator}#[bg=#101C2C,fg=#363a4f,bold]î‚´"
                tab_normal_fullscreen   "#[bg=#101C2C,fg=#363a4f]î‚¶#[bg=#363a4f,fg=#eed49f,bold]{name}{fullscreen_indicator}#[bg=#101C2C,fg=#363a4f,bold]î‚´"
                tab_normal_sync         "#[bg=#101C2C,fg=#363a4f]î‚¶#[bg=#363a4f,fg=#eed49f,bold]{name}{sync_indicator}#[bg=#101C2C,fg=#363a4f,bold]î‚´"
                tab_active              "#[bg=#101C2C,fg=#eed49f]î‚¶#[bg=#eed49f,fg=#363a4f,bold]{name}{floating_indicator}#[bg=#101C2C,fg=#eed49f,bold]î‚´"
                tab_active_fullscreen   "#[bg=#101C2C,fg=#eed49f]î‚¶#[bg=#eed49f,fg=#363a4f,bold]{name}{fullscreen_indicator}#[bg=#101C2C,fg=#eed49f,bold]î‚´"
                tab_active_sync         "#[bg=#101C2C,fg=#eed49f]î‚¶#[bg=#eed49f,fg=#363a4f,bold]{name}{sync_indicator}#[bg=#101C2C,fg=#eed49f,bold]î‚´"
                tab_separator           "#[bg=#101C2C] "
                tab_sync_indicator       " ï‘ƒ "
                tab_fullscreen_indicator " َ°ٹ“ "
                tab_floating_indicator   " َ°¹™ "
                tab_truncate_start_format " ïƒ™ +{count} î©¼ "
                tab_truncate_end_format   " î©¼  +{count} ïƒڑ"

                command_memo_command    "bash /Users/neo/Developer/dotfiles/zellij/scripts/mem.sh"
                command_memo_format     "#[fg=#494d64]î؟… {stdout}"
                command_memo_interval   "30"
                command_memo_rendermode "static"

                command_cpu_command    "bash /Users/neo/Developer/dotfiles/zellij/scripts/cpu.sh"
                command_cpu_format     "#[fg=#494d64]ï’¼ {stdout}%"
                command_cpu_interval   "30"
                command_cpu_rendermode "static"

                hide_frame_for_single_pane "false"
                border_enabled  "false"
            }
        }
    }

    // -------------------------------------------------------------------------------------
    // Definition of tabs
    // -------------------------------------------------------------------------------------

    tab name="Main" split_direction="vertical" borderless=true {
        pane focus=true name="ï’‰ " borderless=false
    }
}
